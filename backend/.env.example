# =============================================
# RETAILSENSE AI — Backend Configuration
# =============================================

PORT=3000
FRONTEND_URL=http://localhost:5173

# Databricks SQL Warehouse
DATABRICKS_HOST=your-databricks-host.cloud.databricks.com
DATABRICKS_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXX

# Databricks Catalog & Schema (optional — if tables are qualified)
DATABRICKS_CATALOG=your_catalog
DATABRICKS_SCHEMA=your_schema

# Custom table names (optional — defaults: train_clean, items_clean, stores_clean)
TABLE_TRAIN=train_clean
TABLE_ITEMS=items_clean
TABLE_STORES=stores_clean

# Security
JWT_SECRET=change-this-to-a-random-256-bit-secret
API_KEY=your-internal-api-key

# ML Prediction API
ML_API_URL=http://localhost:8000